# Environment variables for local development
# Copy this file to .env and fill in your values

PORT=5000
NODE_ENV=development

# PostgreSQL connection string
# Local:  postgresql://user:password@localhost:5432/onestyle_db
# Render: automatically set as DATABASE_URL
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/onestyle_db

# Session secret — change this to a long random string in production
SESSION_SECRET=change_this_to_a_random_secret_string

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
